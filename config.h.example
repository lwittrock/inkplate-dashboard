#ifndef CONFIG_H
#define CONFIG_H

// ============================================================================
// Copy this file to config.h. Secrets live in secrets.h (also gitignored).
// Both files are gitignored — never commit them.
// ============================================================================

#include "secrets.h"

// ============================================================================
// LOCATION
// ============================================================================

const float LATITUDE = 52.0705;    // Delft, Netherlands
const float LONGITUDE = 4.3007;

// ============================================================================
// TIMING CONFIGURATION
// ============================================================================

const unsigned long SLEEP_DURATION = 15 * 60;  // seconds

// Night mode: device skips fetches/render between these times.
// Minutes since midnight (so 23 * 60 + 30 = 1410 means 23:30).
// Renamed from NIGHT_START/NIGHT_END (hours) in 2026-05; the rename
// is deliberate so a stale config can't silently misinterpret hours
// as minutes. See CLAUDE.md "boot-path discipline".
const int NIGHT_START_MIN = 23 * 60 + 30;  // 23:30
const int NIGHT_END_MIN   = 6  * 60 + 30;  // 06:30

// ============================================================================
// TRAIN CONFIGURATION
// ============================================================================

// Origin stations and the single transfer destination. The Trip Planner
// (NS API v3) is queried twice — GVC → DEST and GV → DEST — and a per-slot
// picker (A_Calculations.ino) substitutes HS trips when a Centraal slot is
// disrupted. See drawTrains in C_Display.ino for the card layout.
const char* STATION_CODE_CENTRAL     = "GVC";
const char* STATION_CODE_HS          = "GV";
const char* STATION_CODE_DESTINATION = "TBU";  // Tilburg Universiteit

// ============================================================================
// WEATHER & DISPLAY CONSTANTS
// ============================================================================

const char* TIMEZONE = "CET-1CEST,M3.5.0,M10.5.0/3";  // Amsterdam POSIX TZ string

// Minutes between blocking NTP resyncs. The ESP32 RTC keeps running across
// deep sleep and drifts < 1 s/day, so wakes within this window just restore
// the POSIX TZ instead of starting a fresh SNTP query. Default 60 minutes
// covers ~3 of every 4 wakes at SLEEP_DURATION=900 and is more than enough
// accuracy for a HH:MM display.
#define NTP_RESYNC_MIN 60

// ============================================================================
// BUIENRADAR (live KNMI observations — for current weather + 2h rain)
// ============================================================================
// No key required. Open-Meteo is kept for the 24h hourly + 7-day daily
// forecast; Buienradar replaces Open-Meteo's current-conditions and
// 15-min precipitation blocks because its data comes from physical KNMI
// ground stations (10-min cadence) and radar nowcast (5-min cadence),
// avoiding the "phantom cloud" model artefacts.
#define BUIENRADAR_FEED_URL "https://data.buienradar.nl/2.0/feed/json"
#define BUIENRADAR_RAIN_URL "https://gpsgadget.buienradar.nl/data/raintext?lat=%.2f&lon=%.2f"
// Skip stations whose latest reading is older than this many minutes.
#define BUIENRADAR_STALE_MIN 60
// Consensus radius for the icon-category vote across nearby stations.
// Stations within this distance get one vote; mode wins, ties → closest.
// See CLAUDE.md "Buienradar consensus picker" for the rationale.
#define BUIENRADAR_CONSENSUS_KM 30.0f
#define BUIENRADAR_MAX_CANDIDATES 6

// ============================================================================
// OPTIONAL: DEBUG LOGGING
// ============================================================================
// Set to 1 to enable Serial output at 115200 baud. Default 0 saves ~200 ms
// of wake time and avoids UART tx blocking when no monitor is attached.
// #define DEBUG_LOG 1

// ============================================================================
// OPTIONAL: STATIC IP
// ============================================================================
// Skips DHCP (~1–2 s faster connect, less radio time).
// If any of the four are missing, DHCP is used.
// #define WIFI_STATIC_IP "192.168.1.42"
// #define WIFI_GATEWAY   "192.168.1.1"
// #define WIFI_SUBNET    "255.255.255.0"
// #define WIFI_DNS       "192.168.1.1"

// ============================================================================
// OPTIONAL: OTA (Over-The-Air firmware updates)
// ============================================================================
// See docs/ota-updates-plan.md. The manifest URL has a sensible default in
// D_OTA.ino; override here only if you fork the repo or change the manifest
// hosting branch.
// #define OTA_MANIFEST_URL "https://raw.githubusercontent.com/<you>/<repo>/firmware-latest/version.txt"
//
// Phase 2 development knob: force the OTA check on every wake (bypasses
// the once-per-day gate AND the "hour >= NIGHT_END" gate). Turn OFF for
// production — every-wake checks add ~0.03 mAh per wake and accumulate.
// #define OTA_TEST_FORCE_CHECK 1
//
// Show firmware version in the footer next to "Updated HH:MM". Useful
// during initial OTA shakedown; flip OFF once trusted to clean up the UI.
// #define SHOW_VERSION_FOOTER 1

// ============================================================================
// OPTIONAL: REFRESH STRATEGY
// ============================================================================
// Number of wakes between full e-ink refreshes. In between, partial updates
// are used (much lower energy + faster). Full refreshes clear ghosting.
// Default 4 = once per hour at SLEEP_DURATION=900.
// #define FULL_REFRESH_EVERY 4

#endif
